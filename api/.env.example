# Copy this to api/.env and fill in. api/.env is gitignored.
# Generate JWT_SECRET locally with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql://neondb_owner:<password>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=<paste-64-char-hex-here>
FRONTEND_ORIGIN=http://localhost:3000
